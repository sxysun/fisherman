# fisherman-mirror — TDX-deployable mirror endpoint container.
#
# Same shape as feedling-mcp-v1/deploy/Dockerfile. One image is used by
# the Cloud mirror service and the low-trust relay service. State lives
# in the mounted /data volumes; secrets arrive via dstack-KMS-derived env
# at runtime.
#
# Reproducibility:
#  - Base image pinned by sha256 digest.
#  - pip deps pinned + hash-verified via requirements.lock generated by
#    `uv pip compile mirror/requirements.txt --generate-hashes`.
#  - apt is the only remaining source of non-determinism (locked to the
#    base image's apt sources at build time).
#
# To upgrade either pin, regenerate and commit both the new digest and
# the new requirements.lock in the same PR. mirror/deploy/BUILD.md has
# the exact steps.

ARG PYTHON_IMAGE=python@sha256:9e01bf1ae5db7649a236da7be1e94ffbbbdd7a93f867dd0d8d5720d9e1f89fab
FROM ${PYTHON_IMAGE} AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    FISHERMAN_DATA_DIR=/data

WORKDIR /app

# System deps for cryptography wheels that compile from source.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        build-essential \
        libssl-dev \
        libffi-dev \
        curl \
 && rm -rf /var/lib/apt/lists/*

# Hash-verified install. `--require-hashes` fails the build if any
# package drifts from the lockfile, preventing supply-chain swaps.
COPY mirror/deploy/requirements.lock ./requirements.lock
RUN pip install --require-hashes -r requirements.lock

# The Cloud image runs mirror plus the low-trust relay.
COPY fisherman/ ./fisherman/
COPY mirror/    ./mirror/
COPY relay/     ./relay/
# Stub package metadata so `python -m mirror.cli` can resolve the
# `fisherman-mirror` console script when installed via pip later.
COPY pyproject.toml ./

# Release metadata — baked at build time, read at runtime and served
# inside /attestation.fisherman_release so audit clients can show
# "git_commit abc1234" instead of "dev".
ARG FISHERMAN_GIT_COMMIT=dev
ARG FISHERMAN_BUILT_AT=dev
ARG FISHERMAN_IMAGE_DIGEST=sha256:dev
ENV FISHERMAN_GIT_COMMIT=${FISHERMAN_GIT_COMMIT} \
    FISHERMAN_BUILT_AT=${FISHERMAN_BUILT_AT} \
    FISHERMAN_IMAGE_DIGEST=${FISHERMAN_IMAGE_DIGEST}

# Fixed non-root UID so bind-mounted volumes on the host chown predictably.
RUN useradd --system --uid 1000 --home-dir /home/fisherman --create-home fisherman \
 && mkdir -p /data \
 && chown -R fisherman:fisherman /data /app
USER fisherman

EXPOSE 5001 5003 9100

# In TDX deployments dstack-KMS provisions secrets to /etc/secrets/* and
# the mirror reads them at startup. Locally `docker compose up` provides
# an env-file with the same shape.
CMD ["python", "-u", "-m", "mirror.server"]
