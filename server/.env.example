# Postgres — docker-compose default, or replace with your own (e.g. RDS)
DATABASE_URL=postgresql://fisherman:fisherman@localhost:5432/fisherman

# Cloudflare R2 (optional — leave blank to store frames locally in ./frames/)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fisherman

# Encryption — same Fernet key encrypts stored objects + sensitive Postgres fields
# Auto-generated by setup.sh, or: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Ingest server
INGEST_HOST=0.0.0.0
INGEST_PORT=9999

# Auth token — must match FISH_AUTH_TOKEN on the daemon side
# Auto-generated by setup.sh, or: python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_AUTH_TOKEN=
