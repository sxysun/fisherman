# Postgres (RDS)
DATABASE_URL=postgresql://fisherman:changeme@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/fisherman

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fisherman

# Encryption — same Fernet key encrypts R2 objects + sensitive Postgres fields
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Ingest server
INGEST_HOST=0.0.0.0
INGEST_PORT=9999

# Auth token — must match FISH_AUTH_TOKEN on the daemon side
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_AUTH_TOKEN=
