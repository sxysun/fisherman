FISH_SERVER_URL=ws://localhost:9999/ingest
FISH_AUTH_TOKEN=
FISH_CAPTURE_INTERVAL=1.0
FISH_DIFF_THRESHOLD=6
FISH_JPEG_QUALITY=60
FISH_MAX_DIMENSION=1920
# Swift OCR is preferred on macOS; Python OCR remains the fallback when Swift
# returns no usable text.
FISH_SWIFT_VISION_OCR=true
FISH_EXCLUDED_BUNDLES=[]
FISH_EXCLUDED_APPS=[]
FISH_CONTROL_PORT=7891
FISH_FRAME_SOCKET_PATH=~/.fisherman/frame.sock

# Routing — tiered VLM hints
# Comma-separated bundle IDs treated as text-heavy (OCR usually sufficient)
FISH_TEXT_HEAVY_BUNDLES=["com.apple.Terminal","com.googlecode.iterm2","com.microsoft.VSCode","dev.warp.Warp-Stable"]
# dHash distance threshold (0–64). Above this → tier 2 (needs VLM)
FISH_DHASH_ESCALATION_THRESHOLD=20
# Minimum OCR text length to consider text sufficient
FISH_OCR_MIN_TEXT_LENGTH=50

# VLM — local Moondream 0.5B scene understanding (runs on T2 frames only)
# Requires: uv pip install -e ".[vlm]"
FISH_VLM_ENABLED=false
FISH_VLM_INTERVAL=10.0
